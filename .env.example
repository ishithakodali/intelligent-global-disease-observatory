# Application identity
APP_NAME=Intelligent Global Disease Observatory API
APP_VERSION=1.1.0

# Core behavior
CACHE_TTL_SECONDS=600
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
ALERT_POLL_SECONDS=900

# Security
API_KEY=
ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# External source settings
OUTBREAK_FEED_URL=https://www.who.int/rss-feeds/news-english.xml
PROMED_FEED_URL=https://promedmail.org/promed-posts/feed/
HEALTHMAP_FEED_URL=https://www.healthmap.org/en/?rss=1
WHO_GHO_API_BASE=https://ghoapi.azureedge.net/api
NCBI_API_KEY=

# Optional distributed cache (Redis)
REDIS_URL=redis://localhost:6379/0
